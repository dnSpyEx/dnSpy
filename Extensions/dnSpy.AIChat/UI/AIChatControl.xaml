<UserControl x:Class="dnSpy.AIChat.UI.AIChatControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mvvm="clr-namespace:dnSpy.Contracts.MVVM;assembly=dnSpy.Contracts.DnSpy">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>
    <Grid mvvm:InitDataTemplateAP.Initialize="True" Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header / settings bar -->
        <DockPanel Grid.Row="0" Margin="4">
            <TextBlock Text="Provider:" VerticalAlignment="Center" Margin="0,0,4,0" />
            <ComboBox Width="170" ItemsSource="{Binding Providers}" SelectedItem="{Binding SelectedProvider}" />
            <TextBlock Text="  Model:" VerticalAlignment="Center" Margin="6,0,4,0" />
            <TextBox Width="180" Text="{Binding Model, UpdateSourceTrigger=PropertyChanged}" />
            <Button Content="Settings…" Margin="6,0,0,0" Padding="6,1" Command="{Binding OpenSettingsCommand}" />
            <Button Content="Clear" Margin="4,0,0,0" Padding="6,1" Command="{Binding ClearCommand}" />
        </DockPanel>

        <!-- Conversation history -->
        <Border Grid.Row="1" Margin="4,0,4,0" BorderThickness="1" BorderBrush="Gray">
            <ScrollViewer Name="HistoryScrollViewer" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Messages}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="2" Padding="6" CornerRadius="3" BorderThickness="1" BorderBrush="#33808080">
                                <StackPanel>
                                    <DockPanel>
                                        <TextBlock Text="{Binding Role}" FontWeight="Bold" Opacity="0.8" DockPanel.Dock="Left" />
                                        <Button Content="📋"
                                                Width="24"
                                                Height="24"
                                                Margin="4,0,0,0"
                                                VerticalAlignment="Center"
                                                DockPanel.Dock="Right"
                                                ToolTip="Copy message"
                                                Command="{Binding CopyCommand}" />
                                    </DockPanel>
                                    <TextBox Text="{Binding Content, Mode=OneWay}"
                                             IsReadOnly="True"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             TextWrapping="Wrap"
                                             FontFamily="Consolas" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Status + progress -->
        <DockPanel Grid.Row="2" Margin="4,2">
            <ProgressBar DockPanel.Dock="Right" Width="100" Height="6" Margin="4,0,2,0"
                         IsIndeterminate="True" VerticalAlignment="Center"
                         Visibility="{Binding IsSending, Converter={StaticResource BoolToVis}}" />
            <TextBlock Text="{Binding Status}" Opacity="0.8" VerticalAlignment="Center" />
        </DockPanel>

        <!-- Prompt input -->
        <TextBox Grid.Row="3"
                 Name="PromptTextBox"
                 Margin="4"
                 MinHeight="60"
                 MaxHeight="180"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 Text="{Binding PromptText, UpdateSourceTrigger=PropertyChanged}" />

        <!-- Send buttons -->
        <DockPanel Grid.Row="4" Margin="4,0,4,4">
            <CheckBox Content="Include current selection" IsChecked="{Binding IncludeSelection}" VerticalAlignment="Center" />
            <Button DockPanel.Dock="Right" Content="Send (Ctrl+Enter)" Padding="10,3" Command="{Binding SendCommand}" />
            <Button DockPanel.Dock="Right" Content="Stop" Padding="10,3" Margin="0,0,4,0" Command="{Binding CancelCommand}" />
            <Rectangle />
        </DockPanel>
    </Grid>
</UserControl>
